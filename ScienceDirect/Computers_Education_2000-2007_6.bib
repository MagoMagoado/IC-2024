@article{CATES2002385,
title = {Systematic selection and implementation of graphical user interface metaphors},
journal = {Computers & Education},
volume = {38},
number = {4},
pages = {385-397},
year = {2002},
issn = {0360-1315},
doi = {https://doi.org/10.1016/S0360-1315(01)00064-1},
url = {https://www.sciencedirect.com/science/article/pii/S0360131501000641},
author = {Ward Mitchell Cates},
keywords = {Human–computer interface, Multimedia/hypermedia systems, Interactive learning environments, Navigation},
abstract = {This article begins with a discussion of what metaphors are and how they might be used in technology-based learning products' interfaces. It identifies two classes of metaphors: underlying and auxiliary. Next it presents a model (POPITS) for identifying the web of related associations inherent in metaphorical design. It then applies that model to two separate underlying metaphors, the book and the map, and shows what sorts of auxiliary metaphors are thus elicited. The article closes with a discussion of the demands of metaphorical interface design.}
}
