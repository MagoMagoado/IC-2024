   issue = {1},
   journal = {BRITISH JOURNAL OF EDUCATIONAL TECHNOLOGY},
   keywords = {HIGH-SCHOOL-STUDENTS,TAIWAN},
   pages = {167-170},
   title = {The relationship between internet perceptions and preferences towards internet-based learning environment},
   volume = {38},
