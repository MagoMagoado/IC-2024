}
@article{Magoulas2003,
   abstract = {The idea of developing educational hypermedia systems for the Web is very challenging, and demands the synergy of computer science and instructional science. The paper builds on theories from instructional design and learning styles to develop a design rational and guidelines for adaptive web-based learning systems that use individual differences as a basis of system's adaptation. Various examples are provided to illustrate how instructional manipulations with regards to content adaptation and presentation, and adaptive navigation support, as well as the overall degree of system adaptation, are guided by educational experiences geared towards individual differences.},
   author = {G D Magoulas and K Papanikolaou and M Grigoriadou},
   doi = {10.1111/1467-8535.00347},
   issue = {4},
   journal = {BRITISH JOURNAL OF EDUCATIONAL TECHNOLOGY},
   keywords = {COGNITIVE STYLES,COURSEWARE,EDUCATION,GTE,HYPERMEDIA,INSTRUCTION,MODEL,TEACHING STYLES},
   pages = {511-527},
   title = {Adaptive web-based learning: accommodating individual differences through system's adaptation},
