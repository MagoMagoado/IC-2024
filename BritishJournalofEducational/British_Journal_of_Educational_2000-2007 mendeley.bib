   author = {R Butson},
   doi = {10.1046/j.0007-1013.2003.00359.x},
   issue = {5},
   journal = {BRITISH JOURNAL OF EDUCATIONAL TECHNOLOGY},
   pages = {667-669},
   title = {Learning objects: weapons of mass instruction},
   volume = {34},
